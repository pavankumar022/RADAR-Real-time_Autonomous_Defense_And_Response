# RADAR — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
# The app runs in DEMO MODE without any API keys — no crashes.
# NEVER commit the .env file to version control.
# ============================================================

# --- AI Provider Keys (optional but recommended) ---
# Get a free Gemini API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic Claude (optional — Gemini-only mode works without this)
ANTHROPIC_API_KEY=

# --- AI Provider ---
# gemini | claude
AI_PROVIDER=gemini

# --- Geolocation API ---
# ip-api.com is used by default (free, no key needed, 45 req/min)
# Set GEO_PROVIDER=ipinfo and add your key below to use ipinfo.io instead
GEO_PROVIDER=ipapi
GEO_API_KEY=

# --- Application Config ---
BACKEND_PORT=54321
FRONTEND_ORIGIN=http://localhost:54321
LOG_LEVEL=INFO

# --- Security ---
# Set to a random 32-char string for extra security
SECRET_KEY=change_me_in_production_32chars_min

# --- Database ---
# Relative to the radar/ directory — do not change unless you need a custom path
DATABASE_PATH=./radar.db

# --- Replay Engine ---
REPLAY_MAX_EVENTS_PER_SEC=500
